##
# @brief .gitignore list

# ignore build directory
/build
/builddir
.cache/
.idea/

# jni build files
libs/
obj/
ml_api_common/

# tflite for applications
tensorflow-1.13.1
tensorflow-2.3.0

# data files for applications
Applications/**/data
cifar-100-binary*
Applications/**/*.bin
# model weight checkpoints (*.pt at repo root are local/exported artifacts, not source)
/*.pt
Applications/**/res/*
!Applications/quick_ai/res/deberta_v2/
Applications/quick_ai/res/deberta_v2/*
!Applications/quick_ai/res/deberta_v2/weight_converter.py
!Applications/quick_ai/res/xlm_roberta/
Applications/quick_ai/res/xlm_roberta/*
!Applications/quick_ai/res/xlm_roberta/weight_converter.py
!Applications/quick_ai/res/xlm_roberta/nntr_config.json
!Applications/quick_ai/res/gemma4/
Applications/quick_ai/res/gemma4/*
!Applications/quick_ai/res/gemma4/weight_converter.py
!Applications/quick_ai/res/gemma4/nntr_config.json
!Applications/quick_ai/res/gemma4/test/
Applications/quick_ai/res/gemma4/test/*
!Applications/quick_ai/res/gemma4/test/generate_gemma4_reference.py
!Applications/quick_ai/res/qwen3/
Applications/quick_ai/res/qwen3/*
!Applications/quick_ai/res/qwen3/test/
Applications/quick_ai/res/qwen3/test/*
!Applications/quick_ai/res/qwen3/test/generate_qwen3_moe_reference.py
!Applications/quick_ai/res/qwen3/test/generate_qwen3_reference.py
Applications/**/tokenizers-cpp-build/*

# CTag
/tags
/TAGS

# vi files
*.h~
*.c~
*.cc~
*.sw?

# vscode settings
/.vscode

# binary files
*.out
*.in
*.info
*.so
*.o
*.a
# allow tokenizer lib only
!Applications/quick_ai/lib/libtokenizers_c.a

*.o.d
*.nnlayergolden
*.nnmodelgolden

# log files
*.log

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# flatbuffer compiled header
*_generated.h

# android build
nntrainer_for_android.tar.gz

# gtest
**/jni/googletest/

# encoder related files (download from resource repo)
ctre-unicode.hpp
encoder.hpp
json.hpp


# YOLOv11 local build artifacts (NDK build outputs / PyTorch checkpoints, not source)
Applications/CausalLM/models/YOLOv11/jni/
yolo11*.pt
