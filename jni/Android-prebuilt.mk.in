LOCAL_PATH := $(call my-dir)

# Flags the prebuilt nntrainer libraries were built with. -march selects the
# instruction set; the FP16 defines gate the _FP16 type in the public headers
# (tensor_dim.h), so consumers must compile with the same values or the ABI
# breaks. Exported automatically to every module that links these prebuilts.
NNTRAINER_EXPORT_CFLAGS := @MESON_ARM_MARCH@ @NNTRAINER_ABI_DEFINES@

include $(CLEAR_VARS)

LOCAL_MODULE := ccapi-nntrainer

LOCAL_SRC_FILES := $(LOCAL_PATH)/lib/$(TARGET_ARCH_ABI)/libccapi-nntrainer.so
LOCAL_EXPORT_C_INCLUDES := $(LOCAL_PATH)/include
LOCAL_EXPORT_CFLAGS := $(NNTRAINER_EXPORT_CFLAGS)

include $(PREBUILT_SHARED_LIBRARY)

include $(CLEAR_VARS)

LOCAL_MODULE := nntrainer

LOCAL_SRC_FILES := $(LOCAL_PATH)/lib/$(TARGET_ARCH_ABI)/libnntrainer.so
LOCAL_EXPORT_C_INCLUDES := $(LOCAL_PATH)/include $(LOCAL_PATH)/include/nntrainer
LOCAL_EXPORT_CFLAGS := $(NNTRAINER_EXPORT_CFLAGS)

include $(PREBUILT_SHARED_LIBRARY)
